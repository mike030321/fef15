[Unit]
Description=FEF15 Backend
After=network.target

[Service]
Type=simple
User=www-data
WorkingDirectory=/var/www/fef15/backend
ExecStart=/usr/bin/node server.js
Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal
SyslogIdentifier=fef15
Environment=NODE_ENV=production

[Install]
WantedBy=multi-user.target
